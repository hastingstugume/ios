# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ios_user:ios_password@localhost:5433/ios_dev"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth / Sessions ──────────────────────────────────────────────────────────
SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
SESSION_EXPIRY_DAYS=30
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
MFA_ISSUER="Opportunity Scanner"

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=3001
API_BASE_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="Flowtunity"
NEXT_PUBLIC_BILLING_CONTACT_EMAIL="REPLACE_WITH_YOUR_CONTACT_EMAIL"

# ─── Stripe Billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="REPLACE_WITH_YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET"
# Use Stripe Price IDs (price_...), not raw amounts.
STRIPE_PRICE_STARTER_MONTHLY="REPLACE_WITH_YOUR_PRICE_ID"
STRIPE_PRICE_GROWTH_MONTHLY="REPLACE_WITH_YOUR_PRICE_ID"
STRIPE_PRICE_SCALE_MONTHLY="REPLACE_WITH_YOUR_PRICE_ID"

# ─── AI Provider ─────────────────────────────────────────────────────────────
# OpenAI-compatible endpoint (OpenAI, Together AI, Groq, etc.)
AI_PROVIDER_BASE_URL="https://api.openai.com/v1"
AI_API_KEY="sk-replace-with-your-key"
AI_MODEL="gpt-4o-mini"
AI_MAX_TOKENS=1024

# ─── Search Provider ─────────────────────────────────────────────────────────
# WEB_SEARCH_PROVIDER=legacy is fine for local testing only.
# For wider rollout, configure an approved provider such as SerpApi.
WEB_SEARCH_PROVIDER="legacy"
SERPAPI_API_KEY=""
SAM_GOV_API_KEY=""

# ─── Reddit API ───────────────────────────────────────────────────────────────
# Create app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID="replace-with-client-id"
REDDIT_CLIENT_SECRET="replace-with-client-secret"
REDDIT_USER_AGENT="InternetOpportunityScanner/0.1 by YourUsername"

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@opportunity-scanner.io"
SENDGRID_FROM_NAME="Internet Opportunity Scanner"

# ─── S3-compatible Storage (optional) ────────────────────────────────────────
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET="ios-exports"
STORAGE_REGION="us-east-1"

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=500
RATE_LIMIT_GLOBAL_WINDOW_MS=60000

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
TRUST_PROXY=false
